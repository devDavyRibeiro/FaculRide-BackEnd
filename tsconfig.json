{
  "compilerOptions": {
    "target": "ES2023",          // Alinhado com o MongoDB
    "lib": ["ES2023", "DOM"],    // Adiciona suporte às bibliotecas de 2023
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true         // Mantém isso para ignorar avisos menores
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}